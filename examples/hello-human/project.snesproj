  "eventChains": [
    {
      "id": "robot_hint_chain",
      "name": "Robot Hint Chain",
      "trigger": {
        "type": "actor_interact",
        "actor": "robot"
      },
      "steps": [
        {
          "id": "face",
          "type": "face_player",
          "actor": "robot"
        },
        {
          "id": "text",
          "type": "show_text",
          "text": "Press A to talk. Press B to jump."
        },
        {
          "id": "flag",
          "type": "set_flag",
          "flag": "met_robot",
          "value": true
        },
        {
          "id": "branch",
          "type": "if_flag",
          "flag": "boss_defeated",
          "then": [
            {
              "id": "done",
              "type": "show_text",
              "text": "You saved the school!"
            }
          ],
          "else": [
            {
              "id": "todo",
              "type": "show_text",
              "text": "Find the key before the boss."
            }
          ]
        }
      ]
    },
    {
      "id": "sign_hint",
      "name": "Sign Hint",
      "trigger": {
        "type": "actor_interact",
        "actor": "sign"
      },
      "steps": [
        {
          "id": "sign_text",
          "type": "show_text",
          "text": "Robots like clear instructions."
        }
      ]
    }
  ]
