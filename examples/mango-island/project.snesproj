  "eventChains": [
    {
      "id": "dock_intro",
      "name": "Dock Intro",
      "trigger": {
        "type": "scene_start",
        "scene": "dock"
      },
      "steps": [
        {
          "id": "di1",
          "type": "show_text",
          "text": "Mango Island: a tiny pirate tale.",
          "then": [],
          "else": []
        },
        {
          "id": "di2",
          "type": "show_text",
          "text": "Find a map, win a mug, bribe a lookout, open the vault.",
          "then": [],
          "else": []
        }
      ]
    },
    {
      "id": "talk_captain",
      "name": "Talk Captain",
      "trigger": {
        "type": "actor_interact",
        "actor": "captain_dock"
      },
      "steps": [
        {
          "id": "tc1",
          "type": "show_text",
          "text": "Captain Brine: Treasure hunting starts with paperwork.",
          "then": [],
          "else": []
        },
        {
          "id": "tc2",
          "type": "show_text",
          "text": "Try the tavern. Someone always lost a map there.",
          "then": [],
          "else": []
        }
      ]
    },
    {
      "id": "talk_monkey",
      "name": "Talk Lookout",
      "trigger": {
        "type": "actor_interact",
        "actor": "monkey_dock"
      },
      "steps": [
        {
          "id": "tm1",
          "type": "show_text",
          "text": "Tiny Lookout: No mug, no cave gossip.",
          "then": [],
          "else": []
        }
      ]
    },
    {
      "id": "go_tavern",
      "name": "Go Tavern",
      "trigger": {
        "type": "zone_enter",
        "zone": "dock_to_tavern"
      },
      "steps": [
        {
          "id": "gt",
          "type": "change_scene",
          "scene": "tavern",
          "then": [],
          "else": []
        }
      ]
    },
    {
      "id": "tavern_intro",
      "name": "Tavern Intro",
      "trigger": {
        "type": "scene_start",
        "scene": "tavern"
      },
      "steps": [
        {
          "id": "ti1",
          "type": "show_text",
          "text": "The Bent Compass smells like salt, smoke, and bad wagers.",
          "then": [],
          "else": []
        }
      ]
    },
    {
      "id": "talk_barkeep",
      "name": "Talk Barkeep",
      "trigger": {
        "type": "actor_interact",
        "actor": "barkeep"
      },
      "steps": [
        {
          "id": "tb1",
          "type": "show_text",
          "text": "Barkeep: A map piece for a joke? Fine. Make it short.",
          "then": [],
          "else": []
        },
        {
          "id": "tb2",
          "type": "show_text",
          "text": "Rookie: Why did the pirate alphabet stop at R?",
          "then": [],
          "else": []
        },
        {
          "id": "tb3",
          "type": "show_text",
          "text": "Barkeep: Because the sea took the rest. Terrible. Take it.",
          "then": [],
          "else": []
        },
        {
          "id": "tb_flag",
          "type": "set_flag",
          "flag": "map_piece",
          "value": true,
          "then": [],
          "else": []
        },
        {
          "id": "tb_mug",
          "type": "set_flag",
          "flag": "got_mug",
          "value": true,
          "then": [],
          "else": []
        },
        {
          "id": "tb4",
          "type": "show_text",
          "text": "You got a cracked mug and a damp map piece.",
          "then": [],
          "else": []
        }
      ]
    },
    {
      "id": "go_jungle",
      "name": "Go Jungle",
      "trigger": {
        "type": "zone_enter",
        "zone": "tavern_to_jungle"
      },
      "steps": [
        {
          "id": "gj",
          "type": "change_scene",
          "scene": "jungle",
          "then": [],
          "else": []
        }
      ]
    },
    {
      "id": "trade_monkey",
      "name": "Trade Lookout",
      "trigger": {
        "type": "actor_interact",
        "actor": "monkey_jungle"
      },
      "steps": [
        {
          "id": "tr_check",
          "type": "if_flag",
          "flag": "got_mug",
          "then": [
            {
              "id": "tr_yes",
              "type": "show_text",
              "text": "Tiny Lookout: A mug! Cave password is 'soggy mango'.",
              "then": [],
              "else": []
            },
            {
              "id": "tr_gate",
              "type": "set_flag",
              "flag": "opened_gate",
              "value": true,
              "then": [],
              "else": []
            }
          ],
          "else": [
            {
              "id": "tr_no",
              "type": "show_text",
              "text": "Tiny Lookout: Bring me tavern treasure first. Preferably ceramic.",
              "then": [],
              "else": []
            }
          ]
        }
      ]
    },
    {
      "id": "go_cave",
      "name": "Go Cave",
      "trigger": {
        "type": "zone_enter",
        "zone": "jungle_to_cave"
      },
      "steps": [
        {
          "id": "gc",
          "type": "change_scene",
          "scene": "cave",
          "then": [],
          "else": []
        }
      ]
    },
    {
      "id": "open_cave",
      "name": "Open Cave",
      "trigger": {
        "type": "actor_interact",
        "actor": "captain_cave"
      },
      "steps": [
        {
          "id": "oc_check",
          "type": "if_flag",
          "flag": "opened_gate",
          "then": [
            {
              "id": "oc_yes",
              "type": "show_text",
              "text": "Captain Brine: Soggy mango? Correct. The door sulks open.",
              "then": [],
              "else": []
            }
          ],
          "else": [
            {
              "id": "oc_no",
              "type": "show_text",
              "text": "Captain Brine: The door wants a password and better manners.",
              "then": [],
              "else": []
            }
          ]
        }
      ]
    },
    {
      "id": "enter_vault",
      "name": "Enter Vault",
      "trigger": {
        "type": "zone_enter",
        "zone": "cave_to_vault"
      },
      "steps": [
        {
          "id": "ev_check",
          "type": "if_flag",
          "flag": "opened_gate",
          "then": [
            {
              "id": "ev_go",
              "type": "change_scene",
              "scene": "vault",
              "then": [],
              "else": []
            }
          ],
          "else": [
            {
              "id": "ev_no",
              "type": "show_text",
              "text": "The stone door refuses to move.",
              "then": [],
              "else": []
            }
          ]
        }
      ]
    },
    {
      "id": "open_chest",
      "name": "Open Chest",
      "trigger": {
        "type": "actor_interact",
        "actor": "treasure"
      },
      "steps": [
        {
          "id": "ch1",
          "type": "show_text",
          "text": "The chest opens with a heroic creak.",
          "then": [],
          "else": []
        },
        {
          "id": "ch2",
          "type": "show_text",
          "text": "Inside: one golden mango and a note saying 'Share nicely.'",
          "then": [],
          "else": []
        },
        {
          "id": "ch_flag",
          "type": "set_flag",
          "flag": "treasure_found",
          "value": true,
          "then": [],
          "else": []
        },
        {
          "id": "ch_score",
          "type": "set_variable",
          "variable": "score",
          "value": 100,
          "then": [],
          "else": []
        }
      ]
    }
  ],
