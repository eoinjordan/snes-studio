  "eventChains": [
    {
      "id": "title_intro",
      "name": "Title Intro",
      "trigger": {
        "type": "scene_start",
        "scene": "title"
      },
      "steps": [
        {
          "id": "ti1",
          "type": "show_text",
          "text": "POCKET BUGS",
          "then": [],
          "else": []
        },
        {
          "id": "ti2",
          "type": "show_text",
          "text": "Catch garden bugs. Battle in matchboxes.",
          "then": [],
          "else": []
        },
        {
          "id": "ti3",
