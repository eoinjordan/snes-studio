void snesstudio_on_action(void) {
{% for scene in project.scenes %}
    if (snesstudio_str_eq(current_scene_id, "{{ scene.id }}")) {
{% for actor in scene.actors %}{% set ev = actor.events.get('interact') if actor.events else None %}
{% if ev %}
        if (snesstudio_player_near({{ actor.x }}, {{ actor.y }}, 16, 16)) { event_{{ ev|c_ident }}(); return; }
{% endif %}
{% endfor %}
        return;
    }
{% endfor %}
}

void snesstudio_on_step(void) {
{% for scene in project.scenes %}
    if (snesstudio_str_eq(current_scene_id, "{{ scene.id }}")) {
{% for zone in scene.triggers %}
{% if zone.event %}
        if (snesstudio_player_in_zone({{ zone.x }}, {{ zone.y }}, {{ zone.w }}, {{ zone.h }})) {
            if (!fired_{{ scene.id|c_ident }}_{{ zone.id|c_ident }}) {
                fired_{{ scene.id|c_ident }}_{{ zone.id|c_ident }} = 1;
                event_{{ zone.event|c_ident }}();
                return;
            }
        } else {
            fired_{{ scene.id|c_ident }}_{{ zone.id|c_ident }} = 0;
        }
{% endif %}
{% endfor %}
        return;
    }
{% endfor %}
}

void load_scene(const char *scene_id) {
    snesstudio_log("Loading scene");
{% for scene in project.scenes %}
    if (snesstudio_str_eq(scene_id, "{{ scene.id }}")) {
        current_scene_id = "{{ scene.id }}";
        snesstudio_set_scene("{{ scene.id }}", "{{ scene.name }}");
{% for actor in scene.actors %}
        snesstudio_place_actor("{{ actor.id }}", "{{ actor.name }}", {{ actor.x }}, {{ actor.y }}, "{{ actor.sprite or '' }}");
{% endfor %}
{% for chain in project.eventChains %}{% if chain.trigger and chain.trigger.type == 'scene_start' and chain.trigger.scene == scene.id %}
        event_{{ chain.id|c_ident }}();  /* scene_start */
{% endif %}{% endfor %}
        return;
    }
{% endfor %}
}

int main(void) {
    snesstudio_init("{{ project.rom.title }}");
    snesstudio_show_start_menu("{{ project.rom.title }}");
{% set boot_scene = project.scenes[1].id if project.scenes|length > 1 and project.scenes[0].id == 'title' else (project.scenes[0].id if project.scenes else 'start') %}
    load_scene("{{ boot_scene }}");
{% for chain in project.eventChains %}
{% if chain.trigger and chain.trigger.type == 'scene_start' and not chain.trigger.scene %}
    event_{{ chain.id|c_ident }}();  /* unbound scene_start: runs on first scene */
{% endif %}
{% endfor %}
    while (1) {
        snesstudio_update();
    }
    return 0;
}
