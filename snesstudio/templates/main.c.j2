#include "snesstudio_runtime.h"

/*
 * Generated by SNES Studio 1.0.0.
 * This file is designed to be readable for learners and mentors.
 */

{% for chain in project.eventChains %}
void event_{{ chain.id|c_ident }}(void) {
{{ chain|chain_body }}
}

{% endfor %}
void load_scene(const char *scene_id) {
    snesstudio_log("Loading scene");
{% for scene in project.scenes %}
    if (snesstudio_str_eq(scene_id, "{{ scene.id }}")) {
        snesstudio_set_scene("{{ scene.id }}", "{{ scene.name }}");
{% for actor in scene.actors %}
        snesstudio_place_actor("{{ actor.id }}", "{{ actor.name }}", {{ actor.x }}, {{ actor.y }}, "{{ actor.sprite or '' }}");
{% endfor %}
{% for chain in project.eventChains %}{% if chain.trigger and chain.trigger.type == 'scene_start' and chain.trigger.scene == scene.id %}
        event_{{ chain.id|c_ident }}();  /* scene_start */
{% endif %}{% endfor %}
        return;
    }
{% endfor %}
}

int main(void) {
    snesstudio_init("{{ project.rom.title }}");
    load_scene("{{ project.scenes[0].id if project.scenes else 'start' }}");
{% for chain in project.eventChains %}
{% if chain.trigger and chain.trigger.type == 'scene_start' and not chain.trigger.scene %}
    event_{{ chain.id|c_ident }}();  /* unbound scene_start: runs on first scene */
{% endif %}
{% endfor %}
    while (1) {
        snesstudio_update();
    }
    return 0;
}
