;==LoRom==  SNES cartridge header, generated by SNES Studio for PVSnesLib (wla-65816).

.MEMORYMAP
  SLOTSIZE $8000
  DEFAULTSLOT 0
  SLOT 0 $8000
  SLOT 1 $0 $2000
  SLOT 2 $2000 $E000
  SLOT 3 $0 $10000
.ENDME

.ROMBANKSIZE $8000
.ROMBANKS 8

.SNESHEADER
  ID "SNES"

  NAME "{{ "%-21.21s"|format(project.rom.title) }}"
  ;    "123456789012345678901"

  SLOWROM
  LOROM

  CARTRIDGETYPE $00
  ROMSIZE $08
  SRAMSIZE $00
  COUNTRY ${{ "%02x"|format(2 if project.rom.region == "PAL" else 1) }}   ; {{ project.rom.region }} ($01=US/NTSC, $02=Europe/PAL)
  LICENSEECODE $00
  VERSION $00
.ENDSNES

.SNESNATIVEVECTOR
  COP EmptyHandler
  BRK EmptyHandler
  ABORT EmptyHandler
  NMI VBlank
  IRQ EmptyHandler
.ENDNATIVEVECTOR

.SNESEMUVECTOR
  COP EmptyHandler
  ABORT EmptyHandler
  NMI EmptyHandler
  RESET tcc__start
  IRQBRK EmptyHandler
.ENDEMUVECTOR
