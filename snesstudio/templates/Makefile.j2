# Generated by SNES Studio — PVSnesLib build.
#
# Real SNES ROM build. Requires PVSnesLib installed and PVSNESLIB_HOME set.
# See the project README, section "PVSnesLib toolchain setup".
#
#   make            -> build game.sfc (needs PVSnesLib)
#   make clean
#
# For toolchain-free logic testing, run `snes-studio play <project>` instead.

ifeq ($(strip $(PVSNESLIB_HOME)),)
$(error PVSNESLIB_HOME is not set. Install PVSnesLib and export PVSNESLIB_HOME — see README.)
endif

include $(PVSNESLIB_HOME)/devkitsnes/snes_rules

ROMNAME := game
# Real-runtime engine sources (assets/tilemaps are pre-converted by SNES Studio,
# so no external graphics conversion step is needed here).
OBJS := main.obj snesstudio_snes.obj snesstudio_assets.obj snesstudio_maps.obj

.PHONY: all clean

all: $(ROMNAME).sfc

$(ROMNAME).sfc: $(OBJS)

clean: cleanBuildRes cleanRom cleanGfx
