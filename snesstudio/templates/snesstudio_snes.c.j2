#include <snes.h>
#include <string.h>
#include "snesstudio_assets.h"
#include "snesstudio_maps.h"
#include "snesstudio_runtime.h"

/*
 * Generated SNES runtime engine (PVSnesLib) — top-down adventure and platformer scenes.
 *
 * This replaces the desktop printf simulation (snesstudio_runtime.c) for real
 * ROM builds. It loads a scene's background tilemap, draws the player sprite,
 * reads the controller, moves the player with tilemap collision, and renders a
 * dialogue box for show_text.
 *
 * Targets PVSnesLib. A few PPU/OAM helper signatures vary slightly between
 * PVSnesLib versions — if a call does not match your installed headers, see the
 * "PVSnesLib toolchain setup" section of the README; the intent of each call is
 * commented so it is easy to adjust.
 */

{% set ns = namespace(player=None) %}
{% if project.scenes %}{% for a in project.scenes[0].actors %}{% if a.sprite and ns.player is none %}{% set ns.player = a %}{% endif %}{% endfor %}{% endif %}
{% set player_sprite_id = ns.player.sprite if ns.player else (project.sprites[0].id if project.sprites else 'kid') %}
{% set player_sprite = player_sprite_id | c_ident %}
{% set sp = namespace(w=16, h=16) %}
{% for sprite in project.sprites %}{% if sprite.id == player_sprite_id %}{% set sp.w = sprite.width %}{% set sp.h = sprite.height %}{% endif %}{% endfor %}

#define BG_WALL_CHAR 3
#define SCENE_MODE_TOPDOWN   0
#define SCENE_MODE_PLATFORM  1
#define WALK_SPEED   1
#define JUMP_SPEED   5
#define GRAVITY_STEP 1
#define MAX_FALL     5
#define SPR_W        {{ sp.w }}
#define SPR_H        {{ sp.h }}
#define SPR_OAM_SIZE {{ 'OBJ_SIZE32_L64' if sp.w >= 32 or sp.h >= 32 else 'OBJ_SIZE16_L32' }}
#define SPR_OAM_EX   {{ 'OBJ_SMALL' if sp.w >= 32 or sp.h >= 32 else 'OBJ_SMALL' }}
#define TEXTBOX_X    1
#define TEXTBOX_Y    22
#define TEXTBOX_W    30
#define TEXTBOX_H    4

{% set first = (project.scenes[0].id | c_ident) if project.scenes else 'school' %}
static const unsigned short *current_map = map_{{ first }};
static const unsigned char *current_col = col_{{ first }};
static const unsigned short *current_pal = pal_{{ first }};
static unsigned char current_scene_mode = {{ 'SCENE_MODE_PLATFORM' if project.scenes and project.scenes[0].mode == 'platformer' else 'SCENE_MODE_TOPDOWN' }};
static short player_x = {{ ns.player.x if ns.player else 120 }};
static short player_y = {{ ns.player.y if ns.player else 112 }};
static short player_vy = 0;
static unsigned char awaiting_player_place = 1;
static unsigned short prev_pad = 0;

/* simple story flags */
#define MAX_FLAGS 32
static char flag_names[MAX_FLAGS][24];
static unsigned char flag_vals[MAX_FLAGS];
static int flag_count = 0;

#define MAX_VARIABLES 32
static char variable_names[MAX_VARIABLES][24];
static int variable_vals[MAX_VARIABLES];
static int variable_count = 0;

int snesstudio_str_eq(const char *a, const char *b) { return strcmp(a, b) == 0; }

/* ---- collision against the background tilemap ---- */
static int tile_solid(short px, short py) {
    short tx = px >> 3, ty = py >> 3;
    if (tx < 0 || ty < 0 || tx >= MAP_W || ty >= VISIBLE_ROWS) return 1;
    return current_col[ty * MAP_W + tx];
}
static int blocked(short px, short py) {
    return tile_solid(px, py) || tile_solid(px + SPR_W - 1, py)
        || tile_solid(px, py + SPR_H - 1) || tile_solid(px + SPR_W - 1, py + SPR_H - 1);
}

/* ---- runtime API ---- */
void snesstudio_log(const char *message) { (void)message; }

void snesstudio_init(const char *title) {
    (void)title;
    /* VRAM layout (word addresses), chosen to NOT overlap the text console that
       consoleInit() sets up in low VRAM — overlap caused the striped background:
         text console (consoleInit) : ~0x0000-0x1000
         BG1 game map               : 0x1000
         BG1 game tiles             : 0x4000
         OBJ (sprite) tiles         : 0x6000
       This mirrors PVSnesLib's Mode1Scroll example (background + text together). */
    consoleInit();
    bgInitTileSet(1, (unsigned char *)&gfx_bgtiles, (unsigned char *)current_pal, 0,
                  BG_TILESET_TILES * 32, 16 * 2, BG_16COLORS, 0x4000);
    bgInitMapSet(1, (unsigned char *)current_map, MAP_W * MAP_H * 2, SC_32x32, 0x1000);
    oamInitGfxSet((unsigned char *)&gfx_{{ player_sprite }}_tiles, GFX_{{ player_sprite | upper }}_TILES * 32,
                  (unsigned char *)&pal_{{ player_sprite }}, 16 * 2, 0, 0x6000, SPR_OAM_SIZE);
    oamSet(0, player_x, player_y, 3, 0, 0, 0, 0);
    oamSetEx(0, SPR_OAM_EX, OBJ_SHOW);
    oamSetVisible(0, OBJ_SHOW);   /* required for the sprite to actually draw */
    setMode(BG_MODE1, 0);
    bgSetEnable(0);
    bgSetEnable(1);
    setScreenOn();
}

void snesstudio_show_start_menu(const char *title) {
    unsigned short pad;
    consoleDrawText(9, 7, (char *)title);
    consoleDrawText(4, 10, (char *)"Garden bug battle demo");
    consoleDrawText(6, 13, (char *)"Press START or A");
    consoleDrawText(3, 17, (char *)"Catch bugs. Win the cup.");
    while (1) {
        WaitForVBlank();
        pad = padsCurrent(0);
        if ((pad & KEY_START) || (pad & KEY_A)) break;
    }
    consoleDrawText(3, 7, (char *)"                          ");
    consoleDrawText(3, 10, (char *)"                          ");
    consoleDrawText(3, 13, (char *)"                          ");
    consoleDrawText(3, 17, (char *)"                          ");
}

void snesstudio_set_scene(const char *scene_id, const char *scene_name) {
    (void)scene_name;
    awaiting_player_place = 1;
{% for scene in project.scenes %}
    if (snesstudio_str_eq(scene_id, "{{ scene.id }}")) {
        current_scene_mode = {{ 'SCENE_MODE_PLATFORM' if scene.mode == 'platformer' else 'SCENE_MODE_TOPDOWN' }};
        player_vy = 0;
        current_map = map_{{ scene.id | c_ident }};
        current_col = col_{{ scene.id | c_ident }};
        bgInitTileSet(1, (unsigned char *)&gfx_bgtiles, (unsigned char *)&pal_{{ scene.id | c_ident }}, 0,
                      BG_TILESET_TILES * 32, 16 * 2, BG_16COLORS, 0x4000);
        bgInitMapSet(1, (unsigned char *)current_map, MAP_W * MAP_H * 2, SC_32x32, 0x1000);
        bgSetEnable(0);
        bgSetEnable(1);
        return;
    }
{% endfor %}
}

void snesstudio_place_actor(const char *actor_id, const char *name, int x, int y, const char *sprite) {
    (void)actor_id; (void)name; (void)sprite;
    if (awaiting_player_place) {
        player_x = x;
        player_y = y;
        awaiting_player_place = 0;
    }
}

static int rect_hit(short ax, short ay, short aw, short ah, short bx, short by, short bw, short bh) {
    return ax < bx + bw && ax + aw > bx && ay < by + bh && ay + ah > by;
}

int snesstudio_player_in_zone(int x, int y, int w, int h) {
    return rect_hit(player_x, player_y, SPR_W, SPR_H, x, y, w, h);
}

int snesstudio_player_near(int x, int y, int w, int h) {
    return rect_hit(player_x - 8, player_y - 8, SPR_W + 16, SPR_H + 16, x, y, w, h);
}

static void textbox_clear(void) {
    int row;
    for (row = 0; row < TEXTBOX_H; row++) {
        consoleDrawText(TEXTBOX_X, TEXTBOX_Y + row, (char *)"                              ");
    }
}

static void textbox_frame(void) {
    consoleDrawText(TEXTBOX_X, TEXTBOX_Y + 0, (char *)"+----------------------------+");
    consoleDrawText(TEXTBOX_X, TEXTBOX_Y + 1, (char *)"|                            |");
    consoleDrawText(TEXTBOX_X, TEXTBOX_Y + 2, (char *)"|                            |");
    consoleDrawText(TEXTBOX_X, TEXTBOX_Y + 3, (char *)"+----------------------------+");
}

/* dialogue box: framed text area + wait for A */
void snesstudio_show_text(const char *text) {
    char line1[29], line2[29];
    int i = 0;
    memset(line1, ' ', 28);
    line1[28] = '\0';
    while (i < 28 && text[i]) { line1[i] = text[i]; i++; }
    i = 0;
    memset(line2, ' ', 28);
    line2[28] = '\0';
    while (i < 28 && text[28 + i]) { line2[i] = text[28 + i]; i++; }

    textbox_clear();
    textbox_frame();
    consoleDrawText(TEXTBOX_X + 1, TEXTBOX_Y + 1, line1);
    consoleDrawText(TEXTBOX_X + 1, TEXTBOX_Y + 2, line2);
    consoleDrawText(TEXTBOX_X + 20, TEXTBOX_Y + 3, (char *)"A:continue");
    while (1) {
        WaitForVBlank();
        if (padsCurrent(0) & KEY_A) break;
    }
    textbox_clear();
}

void snesstudio_change_scene(const char *scene_id) { snesstudio_set_scene(scene_id, scene_id); }
void snesstudio_move_actor(const char *actor_id, int dx, int dy) { (void)actor_id; player_x += dx; player_y += dy; }
void snesstudio_face_player(const char *actor_id) { (void)actor_id; }

void snesstudio_set_flag(const char *flag, int value) {
    int i;
    for (i = 0; i < flag_count; i++)
        if (snesstudio_str_eq(flag_names[i], flag)) { flag_vals[i] = value ? 1 : 0; return; }
    if (flag_count < MAX_FLAGS) {
        strncpy(flag_names[flag_count], flag, 23);
        flag_vals[flag_count] = value ? 1 : 0;
        flag_count++;
    }
}
int snesstudio_get_flag(const char *flag) {
    int i;
    for (i = 0; i < flag_count; i++)
        if (snesstudio_str_eq(flag_names[i], flag)) return flag_vals[i];
    return 0;
}

void snesstudio_set_variable(const char *variable, int value) {
    int i;
    for (i = 0; i < variable_count; i++)
        if (snesstudio_str_eq(variable_names[i], variable)) { variable_vals[i] = value; return; }
    if (variable_count < MAX_VARIABLES) {
        strncpy(variable_names[variable_count], variable, 23);
        variable_names[variable_count][23] = '\0';
        variable_vals[variable_count] = value;
        variable_count++;
    }
}
int snesstudio_get_variable(const char *variable) {
    int i;
    for (i = 0; i < variable_count; i++)
        if (snesstudio_str_eq(variable_names[i], variable)) return variable_vals[i];
    return 0;
}

void snesstudio_wait(int frames) { int i; for (i = 0; i < frames; i++) WaitForVBlank(); }
void snesstudio_play_sound(const char *sound) { (void)sound; }
void snesstudio_play_music(const char *music) { (void)music; }
void snesstudio_hide_actor(const char *actor_id) { (void)actor_id; }
void snesstudio_show_actor(const char *actor_id) { (void)actor_id; }
void snesstudio_set_sprite_frame(const char *actor_id, const char *frame) { (void)actor_id; (void)frame; }

/* one gameplay frame: read pad, resolve collision, draw player */
void snesstudio_update(void) {
    unsigned short pad = padsCurrent(0);
    short nx = player_x, ny = player_y;
    if (current_scene_mode == SCENE_MODE_PLATFORM) {
        if (pad & KEY_LEFT)  nx -= WALK_SPEED;
        if (pad & KEY_RIGHT) nx += WALK_SPEED;
        if (!blocked(nx, player_y)) player_x = nx;
        if ((pad & KEY_B) && !(prev_pad & KEY_B) && blocked(player_x, player_y + 1)) player_vy = -JUMP_SPEED;
        if (player_vy < MAX_FALL) player_vy += GRAVITY_STEP;
        ny = player_y + player_vy;
        if (!blocked(player_x, ny)) {
            player_y = ny;
        } else {
            player_vy = 0;
        }
    } else {
        if (pad & KEY_LEFT)  nx -= WALK_SPEED;
        if (pad & KEY_RIGHT) nx += WALK_SPEED;
        if (pad & KEY_UP)    ny -= WALK_SPEED;
        if (pad & KEY_DOWN)  ny += WALK_SPEED;
        if (!blocked(nx, player_y)) player_x = nx;
        if (!blocked(player_x, ny)) player_y = ny;
    }

    if ((pad & KEY_A) && !(prev_pad & KEY_A)) snesstudio_on_action();
    snesstudio_on_step();
    prev_pad = pad;

    oamSet(0, player_x, player_y, 3, 0, 0, 0, 0);
    oamSetEx(0, SPR_OAM_EX, OBJ_SHOW);
    oamSetVisible(0, OBJ_SHOW);
    WaitForVBlank();
}
